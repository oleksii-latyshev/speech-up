PORT=3001

# AI stack mode:
#   docker (default) — everything runs in docker-compose; works on any machine.
#                      Run: docker compose up -d && bun dev
#   native           — macOS only, much faster (Metal GPU). Requires:
#                      brew install ollama && ollama pull qwen3:8b
#                      python3 -m venv local_ai/.venv && local_ai/.venv/bin/pip install -r local_ai/requirements.txt
#                      bun dev then auto-starts/stops ollama serve and local_ai.
AI_MODE=docker

# Explicit URLs override AI_MODE defaults if set:
# OLLAMA_URL=http://localhost:11434
# WHISPER_URL=http://localhost:8001
# KOKORO_URL=http://localhost:8880
